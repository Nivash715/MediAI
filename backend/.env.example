# Backend environment example for MediAI
# Copy to .env and fill values before running

# App
SECRET_KEY=change-me-in-production
DEBUG=True

# InstantDB (required)
INSTANTDB_APP_ID=your_instantdb_app_id_here
INSTANTDB_ADMIN_TOKEN=your_instantdb_admin_token_here

# Optional: OpenAI / Payments / Storage
OPENAI_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=mediai-uploads
